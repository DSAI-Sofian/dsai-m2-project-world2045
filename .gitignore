# =========================================================
# OS / Editor
# =========================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.pytype/
.ipynb_checkpoints/

# =========================================================
# Jupyter
# =========================================================
*.ipynb
!.ipynb_checkpoints/
!notebook/
!notebook/*.ipynb
!main/notebook/
!main/notebook/*.ipynb

# =========================================================
# Logs / temp / cache
# =========================================================
*.log
logs/
tmp/
temp/
.cache/

# =========================================================
# Environment / credentials / secrets
# =========================================================
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*service-account*.json
credentials*.json

# =========================================================
# dbt generated / local-only
# =========================================================
dbt/profiles.yml
dbt/.user.yml
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Keep dbt seeds tracked
!dbt/seeds/
!dbt/seeds/*.csv

# =========================================================
# Data
# =========================================================
# Ignore local working data by default
data/raw/*
data/interim/*
data/processed/*

# Keep directory placeholders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Keep current WPP CSV files tracked for this phase
!data/raw/wpp2024/
!data/raw/wpp2024/**/*.csv

# Explicitly ignore large source workbook
data/raw/wpp2024/*.xlsx

# Common generated data formats outside protected folders
*.parquet
*.tsv
*.jsonl
*.ndjson
*.sqlite
*.duckdb
*.db
*.zip
*.gz

# Allow tracked local sample data for DuckDB notebook
!data/sample/
!data/sample/**/
!data/sample/**/*.parquet

# IMPORTANT:
# Do not globally ignore *.csv or all of data/,
# because this repo intentionally tracks dbt seeds
# and currently keeps WPP raw files in data/raw/wpp2024.

# =========================================================
# Terraform / infrastructure
# =========================================================
infrastructure/**/.terraform/
infrastructure/**/*.tfstate
infrastructure/**/*.tfstate.*
infrastructure/**/.terraform.lock.hcl